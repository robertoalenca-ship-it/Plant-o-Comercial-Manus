# Porta publicada no host
APP_PORT=3000

# Banco MySQL do docker-compose
MYSQL_DATABASE=escala_medica
MYSQL_USER=escala_user
MYSQL_PASSWORD=troque-por-uma-senha-forte
MYSQL_ROOT_PASSWORD=troque-por-uma-senha-root-forte

# Autenticacao local inicial
JWT_SECRET=troque-por-uma-chave-super-forte-e-unica
LOCAL_LOGIN_USERNAME=admin
LOCAL_LOGIN_PASSWORD=troque-por-uma-senha-forte
LOCAL_SESSION_APP_ID=local-auth

# Tempo de espera do app pelo MySQL
DB_WAIT_TIMEOUT_MS=120000
DB_WAIT_INTERVAL_MS=3000

# Integracoes opcionais
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Dominio / CTA publico
APP_URL=https://app.plantaomedico.store
VITE_SALES_CONTACT_URL=https://plantaomedico.store

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_INDIVIDUAL=
STRIPE_PRICE_ID_EXPANSION=
STRIPE_PRICE_ID_ENTERPRISE=
